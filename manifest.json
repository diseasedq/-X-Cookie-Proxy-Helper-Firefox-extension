{
    "manifest_version": 2,
    "name": "X Cookie & Proxy Helper",
    "version": "1.5",
    "description": "Per-tab proxy switch + X.com cookie extractor",
    "permissions": [
        "proxy",
        "cookies",
        "storage",
        "activeTab",
        "tabs",
        "webRequest",
        "webRequestBlocking",
        "downloads",
        "browsingData",
        "clipboardRead",
        "clipboardWrite",
        "<all_urls>"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "x-helper@xrecap.dev",
            "strict_min_version": "91.0"
        }
    },
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "browser_action": {
        "default_popup": "popup.html",
        "default_title": "X Helper",
        "default_icon": "icon.png"
    },
    "icons": {
        "48": "icon.png",
        "128": "icon.png"
    },
    "content_scripts": [
        {
            "matches": [
                "*://x.com/*",
                "*://twitter.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}